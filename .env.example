# .env.example
# Copy this file to .env.local and fill in your actual values.
# Never commit real credentials to version control.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Admin notification email (used for internal alerts)
ADMIN_EMAIL=your_admin_email@yourdomain.com

# ElevenLabs voice agent credentials
# Obtain from: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id_here
ELEVENLABS_WEBHOOK_SECRET=your_elevenlabs_webhook_secret_here
ELEVENLABS_POST_CALL_WEBHOOK_ID=your_post_call_webhook_id_here

# Callback phone number for Devin Maloy (Paycor representative)
# Format: 10-digit US number, no dashes
DEVIN_CALLBACK_PHONE=your_10_digit_callback_phone_here

# Admin authentication secret (used to sign/verify admin session tokens)
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your_strong_random_secret_here

# Calendly integration
# Obtain from: https://calendly.com/integrations/api_webhooks
CALENDLY_API_TOKEN=your_calendly_api_token_here

# Microsoft 365 / Entra (for outreach email dispatch)
MICROSOFT_CLIENT_ID=your_azure_app_client_id_here
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret_here
MICROSOFT_TENANT_ID=your_azure_tenant_id_here
MICROSOFT_REDIRECT_URI=https://ltcroi.com/api/microsoft/callback

# Outreach compliance
OUTREACH_POSTAL_ADDRESS=Your Company Name, 123 Your Street, City, ST 00000

# Live dispatch gate — set to true ONLY after testing drafts in staging
MICROSOFT_LIVE_EMAIL_ENABLED=false
